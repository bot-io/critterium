{
  "name": "@critterium/core",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "development": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./ecosystem": {
      "types": "./src/ecosystem.ts",
      "development": "./src/ecosystem.ts",
      "import": "./src/ecosystem.ts"
    },
    "./ecosystem-world": {
      "types": "./src/ecosystem-world.ts",
      "development": "./src/ecosystem-world.ts",
      "import": "./src/ecosystem-world.ts"
    },
    "./eating": {
      "types": "./src/eating.ts",
      "development": "./src/eating.ts",
      "import": "./src/eating.ts"
    },
    "./lifecycle": {
      "types": "./src/lifecycle.ts",
      "development": "./src/lifecycle.ts",
      "import": "./src/lifecycle.ts"
    },
    "./interaction-rules": {
      "types": "./src/interaction-rules.ts",
      "development": "./src/interaction-rules.ts",
      "import": "./src/interaction-rules.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "typescript": "^5.8.3",
    "vitest": "^3.2.1"
